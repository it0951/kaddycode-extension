{
  "name": "ustracode-extension",
  "displayName": "UstraCode",
  "description": "AI-powered coding assistant for enterprise",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ustracode-sidebar",
          "title": "UstraCode",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "ustracode-sidebar": [
        {
          "type": "webview",
          "id": "ustracode.chatView",
          "name": "AI Chat"
        }
      ]
    },
    "configuration": {
      "title": "UstraCode",
      "properties": {
        "ustracode.serverUrl": {
          "type": "string",
          "default": "http://localhost:8081",
          "description": "UstraCode Internal Server URL"
        },
        "ustracode.apiKey": {
          "type": "string",
          "default": "",
          "description": "테넌트 API Key (Backoffice에서 발급)"
        },
        "ustracode.userId": {
          "type": "string",
          "default": "",
          "description": "사용자 ID (미입력 시 VS Code 머신 ID 자동 사용)"
        },
        "ustracode.defaultProvider": {
          "type": "string",
          "default": "ollama",
          "enum": ["ollama", "openai", "claude", "gemini"],
          "description": "기본 AI 프로바이더"
        },
        "ustracode.defaultModel": {
          "type": "string",
          "default": "qwen2.5-coder:14b",
          "description": "기본 AI 모델명"
        },
        "ustracode.ragEnabled": {
          "type": "boolean",
          "default": true,
          "description": "RAG 컨텍스트 사용 여부"
        },
        "ustracode.autoIndexOnSave": {
          "type": "boolean",
          "default": false,
          "description": "파일 저장 시 자동으로 RAG 인덱싱 (API Key 설정 필요)"
        }
      }
    },
    "commands": [
      {
        "command": "ustracode.chat",
        "title": "UstraCode: AI에게 질문하기"
      },
      {
        "command": "ustracode.indexCurrentFile",
        "title": "UstraCode: 현재 파일 인덱싱"
      },
      {
        "command": "ustracode.searchCode",
        "title": "UstraCode: 코드 검색"
      },
      {
        "command": "ustracode.openChat",
        "title": "UstraCode: 채팅 열기",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "ustracode.openSettings",
        "title": "UstraCode: 설정 열기",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "editor/context": [
        { "command": "ustracode.chat", "group": "ustracode@1" },
        { "command": "ustracode.indexCurrentFile", "group": "ustracode@2" },
        { "command": "ustracode.searchCode", "group": "ustracode@3" }
      ],
      "view/title": [
        {
          "command": "ustracode.indexCurrentFile",
          "when": "view == ustracode.chatView",
          "group": "navigation"
        },
        {
          "command": "ustracode.openSettings",
          "when": "view == ustracode.chatView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
}