{
  "name": "ustracode-extension",
  "displayName": "UstraCode",
  "description": "AI-powered coding assistant for enterprise",
  "version": "0.1.0",
  "publisher": "ustracode",
  "engines": { "vscode": "^1.110.0" },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "activationEvents": ["*"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [{ "id": "ustracode-sidebar", "title": "UstraCode", "icon": "resources/icon.svg" }]
    },
    "views": {
      "ustracode-sidebar": [{ "type": "webview", "id": "ustracode.chatView", "name": "AI Chat" }]
    },
    "configuration": {
      "title": "UstraCode",
      "properties": {
        "ustracode.serverUrl": { "type": "string", "default": "http://localhost:8081", "description": "UstraCode Internal Server URL" },
        "ustracode.email": { "type": "string", "default": "", "description": "Tenant email address" },
        "ustracode.apiKey": { "type": "string", "default": "", "description": "Tenant API Key" },
        "ustracode.userId": { "type": "string", "default": "", "description": "User ID" },
        "ustracode.defaultProvider": { "type": "string", "default": "ollama", "enum": ["ollama","openai","claude","gemini"], "description": "Default AI provider" },
        "ustracode.defaultModel": { "type": "string", "default": "qwen2.5-coder:14b", "description": "Default AI model" },
        "ustracode.ragEnabled": { "type": "boolean", "default": true, "description": "Enable RAG context" },
        "ustracode.autoIndexOnSave": { "type": "boolean", "default": false, "description": "Auto index on save" }
      }
    },
    "commands": [
      { "command": "ustracode.chat", "title": "UstraCode: Ask AI" },
      { "command": "ustracode.indexCurrentFile", "title": "UstraCode: Index Current File" },
      { "command": "ustracode.searchCode", "title": "UstraCode: Search Code" },
      { "command": "ustracode.openChat", "title": "UstraCode: Open Chat", "icon": "$(comment-discussion)" },
      { "command": "ustracode.openSettings", "title": "UstraCode: Open Settings", "icon": "$(settings-gear)" }
    ],
    "menus": {
      "editor/context": [
        { "command": "ustracode.chat", "group": "ustracode@1" },
        { "command": "ustracode.indexCurrentFile", "group": "ustracode@2" },
        { "command": "ustracode.searchCode", "group": "ustracode@3" }
      ],
      "view/title": [
        { "command": "ustracode.indexCurrentFile", "when": "view == ustracode.chatView", "group": "navigation" },
        { "command": "ustracode.openSettings", "when": "view == ustracode.chatView", "group": "navigation" }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": { "axios": "^1.13.6" }
}