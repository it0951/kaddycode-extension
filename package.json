{
  "name": "ustracode-extension",
  "displayName": "UstraCode",
  "description": "AI-powered coding assistant for enterprise",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "ustracode.chat",
        "title": "UstraCode: AI에게 질문하기"
      },
      {
        "command": "ustracode.indexCurrentFile",
        "title": "UstraCode: 현재 파일 인덱싱"
      },
      {
        "command": "ustracode.searchCode",
        "title": "UstraCode: 코드 검색"
      }
    ],
    "menus": {
      "editor/context": [
        { "command": "ustracode.chat", "group": "ustracode@1" },
        { "command": "ustracode.indexCurrentFile", "group": "ustracode@2" },
        { "command": "ustracode.searchCode", "group": "ustracode@3" }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
}