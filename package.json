{
  "name": "kaddycode-extension",
  "displayName": "KaddyCode",
  "description": "AI-powered coding assistant for enterprise",
  "version": "0.1.0",
  "publisher": "kaddycode",
  "engines": { "vscode": "^1.110.0" },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "activationEvents": ["*"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [{ "id": "kaddycode-sidebar", "title": "KaddyCode", "icon": "resources/icon.svg" }]
    },
    "views": {
      "kaddycode-sidebar": [{ "type": "webview", "id": "kaddycode.chatView", "name": "AI Chat" }]
    },
    "configuration": {
      "title": "KaddyCode",
      "properties": {
        "kaddycode.serverUrl": { "type": "string", "default": "http://localhost:8081", "description": "KaddyCode Internal Server URL" },
        "kaddycode.email": { "type": "string", "default": "", "description": "Tenant email address" },
        "kaddycode.apiKey": { "type": "string", "default": "", "description": "Tenant API Key" },
        "kaddycode.userId": { "type": "string", "default": "", "description": "User ID" },
        "kaddycode.defaultProvider": { "type": "string", "default": "ollama", "enum": ["ollama","openai","claude","gemini"], "description": "Default AI provider" },
        "kaddycode.defaultModel": { "type": "string", "default": "qwen2.5-coder:14b", "description": "Default AI model" },
        "kaddycode.ragEnabled": { "type": "boolean", "default": true, "description": "Enable RAG context" },
        "kaddycode.autoIndexOnSave": { "type": "boolean", "default": false, "description": "Auto index on save" },
        "kaddycode.codeLensEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable CodeLens buttons on functions and classes"
        }
      }
    },
    "commands": [
      { "command": "kaddycode.chat", "title": "KaddyCode: Ask AI" },
      { "command": "kaddycode.indexCurrentFile", "title": "KaddyCode: Index Current File" },
      { "command": "kaddycode.searchCode", "title": "KaddyCode: Search Code" },
      { "command": "kaddycode.openChat", "title": "KaddyCode: Open Chat", "icon": "$(comment-discussion)" },
      { "command": "kaddycode.openSettings", "title": "KaddyCode: Open Settings", "icon": "$(settings-gear)" },
      { "command": "kaddycode.checkVersion", "title": "KaddyCode: 버전 확인", "icon": "$(versions)" },
      { "command": "kaddycode.codeLens.explain", "title": "KaddyCode: Explain Code" },
      { "command": "kaddycode.codeLens.fix",     "title": "KaddyCode: Fix / Refactor Code" },
      { "command": "kaddycode.codeLens.ask",     "title": "KaddyCode: Ask AI about Code" },
      { "command": "kaddycode.codeLens.doc",     "title": "KaddyCode: Generate Documentation" },
      { "command": "kaddycode.codeLens.open", "title": "KaddyCode: Open Chat" },
      { "command": "kaddycode.codeLens.noop", "title": "KaddyCode: Separator" }
    ],
    "menus": {
      "editor/context": [
        { "command": "kaddycode.chat", "group": "kaddycode@1" },
        { "command": "kaddycode.indexCurrentFile", "group": "kaddycode@2" },
        { "command": "kaddycode.searchCode", "group": "kaddycode@3" }
      ],
      "view/title": [
        { "command": "kaddycode.indexCurrentFile", "when": "view == kaddycode.chatView", "group": "navigation" },
        { "command": "kaddycode.openSettings", "when": "view == kaddycode.chatView", "group": "navigation" },
        { "command": "kaddycode.checkVersion", "when": "view == kaddycode.chatView", "group": "navigation" }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": { "axios": "^1.13.6" }
}